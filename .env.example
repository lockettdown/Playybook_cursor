# Copy to .env.local for local dev. On Vercel (or Netlify), set the same keys under
# Project → Settings → Environment Variables, then redeploy (NEXT_PUBLIC_* are baked in at build).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Password reset: in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs, add:
# http://localhost:3001/auth/reset-password
# https://YOUR_PRODUCTION_DOMAIN/auth/reset-password
